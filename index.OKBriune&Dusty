    fetch('https://api.openweathermap.org/data/2.5/weather?q=Piove di Sacco&appid=eca827552d285d6fd2783dc704b52c48&units=metric&lang=it')
        .then(r => r.json()).then(d => {
            t = Math.round(d.main.temp);
            m = d.weather[0].main;
            dText = d.weather[0].description;
            document.getElementById('w-temp').innerText = t + "°";
            document.getElementById('w-desc').innerText = dText;
            document.getElementById('w-feels').innerText = Math.round(d.main.feels_like) + "°";
            document.getElementById('w-hum').innerText = d.main.humidity + "%";
            document.getElementById('w-wind').innerText = Math.round(d.wind.speed * 3.6) + " km/h";
            setCustomIcon(m);
            
            const savedHero = localStorage.getItem('mioUnicorno');
            if (savedHero) {
                const btns = document.querySelectorAll('.grid button');
                btns.forEach(b => { if(b.innerText.toLowerCase() === savedHero) seleziona(savedHero, b); });
                if (localStorage.getItem('confermato') === 'true') conferma();
            }
        });

    window.addEventListener('load', () => {
        document.getElementById('disclaimer-overlay').style.display = 'flex';
    });

    function accettaDisclaimer() {
        document.getElementById('disclaimer-overlay').style.display = 'none';
    }

    function seleziona(nome, btn) {
        selected = nome;
        localStorage.setItem('mioUnicorno', nome);
        localStorage.setItem('confermato', 'false'); 
        document.body.className = '';
        document.querySelectorAll('.grid button').forEach(b => b.classList.remove('active'));
        if(btn) btn.classList.add('active');
        
        const u = db[nome];
        document.getElementById('identikit').style.display = "block";
        document.getElementById('char-img').src = nome + ".png";
        
        const usati = [u.ama, u.gradisce, u.nongradisce, u.odia];
        const neutri = condizioniTutte.filter(val => !usati.includes(val));

        document.getElementById('char-prefs').innerHTML = `
            <li><span>😍</span> <b class="label-pref">Ama:</b> <span class="value-pref">${u.ama}</span></li>
            <li><span>😊</span> <b class="label-pref">Gradisce:</b> <span class="value-pref">${u.gradisce}</span></li>
            <li><span>😐</span> <b class="label-pref">Neutro:</b> <span class="value-pref">${neutri.join(', ')}</span></li>
            <li><span>😒</span> <b class="label-pref">Non gradisce:</b> <span class="value-pref">${u.nongradisce}</span></li>
            <li><span>😡</span> <b class="label-pref">Odia:</b> <span class="value-pref">${u.odia}</span></li>
        `;
        document.getElementById('char-prefs').style.display = "block";
        document.getElementById('char-bio').innerText = u.bio;
        document.getElementById('char-bio').style.display = "block";
        document.getElementById('char-mood').style.display = "none";
        document.getElementById('confirm-btn').style.display = "block";

        reaction = 'neutro';
        const wind = Math.round(document.getElementById('w-wind').innerText.split(' ')[0]);
        const hum = parseInt(document.getElementById('w-hum').innerText);

        if(nome === 'vampa') {
            if(t > 30) reaction = 'ama';
            else if(m === 'Clear') reaction = 'gradisce';
            else if(wind > 20) reaction = 'nongradisce';
            else if(t < 15) reaction = 'odia';
        }
        else if(nome === 'gelo') {
            if(t < 5) reaction = 'ama';
            else if(m === 'Snow' || t < 10) reaction = 'gradisce';
            else if(hum > 80) reaction = 'nongradisce';
            else if(t > 25) reaction = 'odia';
        }
        else if(nome === 'goccia') {
            if(m === 'Rain') reaction = 'ama';
            else if(m === 'Drizzle') reaction = 'gradisce';
            else if(m === 'Clouds') reaction = 'nongradisce';
            else if(m === 'Clear') reaction = 'odia';
        }
        else if(nome === 'aureo') {
            if(m === 'Clear') reaction = 'ama';
            else if(t > 25) reaction = 'gradisce';
            else if(m === 'Rain') reaction = 'nongradisce';
            else if(m === 'Mist' || m === 'Fog') reaction = 'odia';
        }
        else if(nome === 'puff') {
            if(m === 'Clouds') reaction = 'ama';
            else if(m === 'Mist' || m === 'Fog') reaction = 'gradisce';
            else if(m === 'Clear') reaction = 'nongradisce';
            else if(m === 'Thunderstorm') reaction = 'odia';
        }
        else if(nome === 'blakie') {
            if(m === 'Thunderstorm') reaction = 'ama';
            else if(m === 'Rain') reaction = 'gradisce';
            else if(m === 'Clouds') reaction = 'nongradisce';
            else if(m === 'Clear') reaction = 'odia';
        }
        else if(nome === 'brina') {
            if(m === 'Snow') reaction = 'ama';
            else if(t < 5) reaction = 'gradisce';
            else if(m === 'Mist' || m === 'Fog') reaction = 'nongradisce';
            else if(m === 'Rain') reaction = 'odia';
        }
        else if(nome === 'dusty') {
            if(m === 'Mist' || m === 'Fog') reaction = 'ama';
            else if(m === 'Clouds') reaction = 'gradisce';
            else if(wind > 15) reaction = 'nongradisce';
            else if(m === 'Clear') reaction = 'odia';
        }
    }

    function conferma() {
        localStorage.setItem('confermato', 'true');
        document.getElementById('char-img').src = selected + reaction + ".png";
        document.body.className = 'bg-' + reaction;
        document.getElementById('identikit').className = 'card border-' + reaction;
        document.getElementById('char-prefs').style.display = "none";
        document.getElementById('char-bio').style.display = "none"; 
        
        const bubble = document.getElementById('char-mood');
        const frasi = db[selected].sarcasmo[reaction]();
        bubble.innerText = frasi[Math.floor(Math.random() * frasi.length)];
        bubble.style.display = "block";
        document.getElementById('confirm-btn').style.display = "none";
        window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
    }
